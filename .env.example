# NutEV / NutMEV environment
# Copy to .env and fill only the keys you actually use.
# Keep real secrets out of version control.

# Network
NUTEV_DISABLE_NETWORK=0
NUTEV_SKIP_PUBMED=0

# NCBI / PubMed
# NCBI_EMAIL is recommended by NCBI; ENTREZ_EMAIL is accepted by NutEV as fallback.
NCBI_EMAIL=
ENTREZ_EMAIL=
NCBI_API_KEY=
NCBI_TOOL=nutev_pipeline
NUTEV_PUBMED_BATCH_SIZE=200
NUTEV_PUBMED_FETCH_ABSTRACTS=0

# Crossref
CROSSREF_MAILTO=

# OpenAlex
OPENALEX_MAILTO=

# DOAJ, ClinicalTrials.gov and SciELO — no key required. Available via the
# provider registry; add the id ("doaj"/"clinicaltrials"/"scielo") to a
# workstream's source_priority to run it. SciELO is scoped to Crossref prefix 10.1590.
NUTEV_SKIP_DOAJ=0
NUTEV_SKIP_CLINICALTRIALS=0
NUTEV_SKIP_SCIELO=0

# Recall depth per REST provider (opt-in). Unset = historical single page
# (reproducible default). Set a bounded cap to paginate for higher recall.
NUTEV_EUROPEPMC_MAX_RESULTS=
NUTEV_CROSSREF_MAX_RESULTS=
NUTEV_OPENALEX_MAX_RESULTS=
NUTEV_DOAJ_MAX_RESULTS=
NUTEV_CLINICALTRIALS_MAX_RESULTS=
NUTEV_SCIELO_MAX_RESULTS=

# Optional Google / gray literature
# Google, SerpAPI and Brave are optional and are not required for scientific searches.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPAPI_API_KEY=
BRAVE_API_KEY=

# Optional LLM
OPENAI_API_KEY=

# Webhook
NUTEV_DIGEST_WEBHOOK_URL=
NUTEV_NOTIFY_WEBHOOK=0

# Debug / limits
NUTEV_LOG_LEVEL=INFO
NUTEV_CAPTURE_LIMIT=
NUTEV_DOWNLOAD_LIMIT=
