# NutEV / NutMEV local example environment
# Copy to .env and fill only the keys you actually use.
# Keep real secrets out of version control.

# Optional LLM provider for summaries/classification
OPENAI_API_KEY=

# Optional web search providers
BRAVE_API_KEY=
SERPAPI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional webhook digest delivery
NUTEV_DIGEST_WEBHOOK_URL=
NUTEV_NOTIFY_WEBHOOK=0

# Local execution toggles
NUTEV_DISABLE_NETWORK=0

# Optional runtime flags commonly used in local debugging
# NUTEV_LOG_LEVEL=INFO
# NUTEV_CAPTURE_LIMIT=1
