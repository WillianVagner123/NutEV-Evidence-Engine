# NutEV / NutMEV environment
# Copy to .env and fill only the keys you actually use.
# Keep real secrets out of version control.

# Network
NUTEV_DISABLE_NETWORK=0
NUTEV_SKIP_PUBMED=0

# NCBI / PubMed
# NCBI_EMAIL is recommended by NCBI; ENTREZ_EMAIL is accepted by NutEV as fallback.
NCBI_EMAIL=
ENTREZ_EMAIL=
NCBI_API_KEY=
NCBI_TOOL=nutev_pipeline
NUTEV_PUBMED_BATCH_SIZE=200
NUTEV_PUBMED_FETCH_ABSTRACTS=0

# Crossref
CROSSREF_MAILTO=

# OpenAlex
OPENALEX_MAILTO=

# Additional scientific databases (all free; no key required to run).
# Semantic Scholar works without a key; set one only to raise rate limits.
SEMANTIC_SCHOLAR_API_KEY=
# DOAJ, SciELO (via Crossref prefix 10.1590), preprints (Europe PMC SRC:PPR)
# and ClinicalTrials.gov require no credentials.
# CORE (core.ac.uk) is optional: set a free key to enable it (adds OA full-text
# coverage and direct PDF downloads); without it CORE is skipped gracefully.
CORE_API_KEY=

# Open-access full-text download (Unpaywall). An e-mail is required by the API;
# NCBI_EMAIL/CROSSREF_MAILTO/OPENALEX_MAILTO are used as fallbacks.
UNPAYWALL_EMAIL=

# Optional Google / gray literature
# Google, SerpAPI and Brave are optional and are not required for scientific searches.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPAPI_API_KEY=
BRAVE_API_KEY=

# Optional LLM
OPENAI_API_KEY=

# Webhook
NUTEV_DIGEST_WEBHOOK_URL=
NUTEV_NOTIFY_WEBHOOK=0

# Debug / limits
NUTEV_LOG_LEVEL=INFO
NUTEV_CAPTURE_LIMIT=
NUTEV_DOWNLOAD_LIMIT=
