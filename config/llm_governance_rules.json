{
  "version": "2026-05-nutev-llm-governance-v1",
  "allowed_llm_roles": [
    "summarization_assist",
    "claim_candidate_assist",
    "translation_assist",
    "method_text_assist"
  ],
  "forbidden_llm_roles": [
    "final_recommendation_approval",
    "human_review_replacement",
    "evidence_fabrication",
    "unsupported_claim_generation"
  ],
  "rules": [
    "LLM output must be marked as assistive.",
    "LLM-generated claims must be inference_only until linked to exact_quote.",
    "LLM cannot change human_approval_status.",
    "LLM cannot set approved_for_protocol.",
    "LLM cannot create supporting_claim_ids without document evidence."
  ]
}
