{
  "version": "2026-05-nutev-recommendation-rules-v1",
  "protocol_components": [
    "diretrizes_dieteticas",
    "piramide_nutev",
    "competencias_alimentares",
    "menus_modelo",
    "adesao_implementacao",
    "nutricao_contingencial",
