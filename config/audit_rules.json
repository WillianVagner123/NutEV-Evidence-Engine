{
  "version": "2026-05-nutev-audit-v1",
  "principles": [
    "No recommendation without supporting claims",
    "No claim without document_id",
    "No final approval without human validation",
    "No inference presented as evidence",
    "Absence of evidence must be recorded as insufficient_evidence"
  ],
  "claim_requirements": {
    "required_fields": ["claim_id", "document_id", "claim_text", "claim_status"],
    "quote_required_for_status": ["supported", "partially_supported"],
    "allow_inference_without_quote": true,
    "inference_status": "inference_only"
  },
  "recommendation_requirements": {
    "minimum_supporting_claims_for_ready_review": 1,
    "minimum_supporting_documents_for_ready_review": 1,
    "human_review_required_for_protocol": true,
    "forbid_approval_without_supporting_claims": true
  },
  "conflict_rules": {
    "conflicting_claims_require_human_review": true,
    "conflicting_evidence_blocks_auto_approval": true
  },
  "status_rules": {
    "unsupported_recommendations_default_status": "draft_needs_evidence",
    "claims_without_quote_default_status": "needs_human_review",
    "metadata_only_documents_claim_status": "needs_human_review"
  }
}
