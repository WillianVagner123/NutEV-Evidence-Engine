{
  "_note": "Extraction schema for the Article 1 pilot. Every extracted field must carry a verifiable source locator.",
  "record": {
    "record_id": "string (stable id)",
    "title": "string",
    "authors": "string",
    "year": "integer",
    "source_type": "enum: official_guide | clinical_guideline | consensus | statement",
    "workstream": "enum: busca1 | busca2a | busca2b",
    "doi": "string | null",
    "official_url": "string | null (official/public URL only)"
  },
  "claim": {
    "claim_id": "string",
    "record_id": "string (foreign key to record)",
    "lifestyle_nutrition_domain": "string (candidate domain label)",
    "claim_text": "string (project-authored paraphrase or minimum permitted excerpt)",
    "source_locator": "string (page/section/paragraph — REQUIRED for traceability)",
    "confidence": "number 0..1 (assistive only; never final approval)",
    "needs_human_review": "boolean (default true)"
  },
  "rules": {
    "traceability_required": true,
    "conflicts_must_be_surfaced": true,
    "llm_may_approve": false,
    "final_decision": "human_review"
  }
}
